# Shared defaults for install-openclaw-api.ps1 and install-openclaw-api.sh
# Keep the provider as built-in "openai" so OpenClaw keeps GPT-5.4 and xhigh behavior.
OPENCLAW_BASE_URL=https://aizhiwen.top
OPENCLAW_MODEL=gpt-5.4
OPENCLAW_REASONING_EFFORT=xhigh
OPENCLAW_PROVIDER_API=openai-responses
OPENCLAW_INSTALL_CHANNEL=latest
